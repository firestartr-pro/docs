      "user_managed": false
    },
    {
      "src": ".github/workflows/sys-services-apply.yml",
      "dest": ".github/workflows/sys-services-apply.yml",
      "user_managed": false
    },
    {
      "src": ".github/workflows/sys-services-manual-apply.yml",
      "dest": ".github/workflows/sys-services-manual-apply.yml",
      "user_managed": false
    },
    {
