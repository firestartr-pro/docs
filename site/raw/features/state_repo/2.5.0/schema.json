{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "build_images args",
  "type": "object",
  "properties": {
    "feature_name": {
      "const": "build_images"
    },
    "sops_enabled": {
      "type": "string",
      "description": "Whether SOPS encryption is enabled for managing secrets.",
      "default": "false",
      "examples": [
        "false"
      ]
    },
    "version_kubectl": {
      "type": "string",
      "description": "The version of kubectl to use in workflows.",
      "default": "1.32.0",
      "examples": [
        "1.32.0"
      ]
    },
    "version_kubectl_release_date": {
      "type": "string",
      "description": "The release date of the kubectl version.",
      "default": "2024-12-20",
      "examples": [
        "2024-12-20"
      ]
    },
    "version_kustomize": {
      "type": "string",
      "description": "The version of kustomize to use in workflows.",
      "default": "5.6.0",
      "examples": [
        "5.6.0"
      ]
    },
    "version_helm": {
      "type": "string",
      "description": "The version of Helm to use in workflows.",
      "default": "v3.16.4",
      "examples": [
        "v3.16.4"
      ]
    },
    "version_helmfile": {
      "type": "string",
      "description": "The version of Helmfile to use in workflows.",
      "default": "v0.169.2",
      "examples": [
        "v0.169.2"
      ]
    },
    "version_helm_diff_plugin": {
      "type": "string",
      "description": "The version of the Helm Diff plugin to use in workflows.",
      "default": "v3.9.13",
      "examples": [
        "v3.9.13"
      ]
    },
    "version_secrets": {
      "type": "string",
      "description": "The version of the secrets management tool to use in workflows.",
      "default": "v4.6.2",
      "examples": [
        "v4.6.2"
      ]
    },
    "version_sops": {
      "type": "string",
      "description": "The version of SOPS to use in workflows.",
      "default": "v3.9.1",
      "examples": [
        "v3.9.1"
      ]
    },
    "dispatch_image_v5_timeout": {
      "type": "string",
      "description": "The timeout in milliseconds for dispatching image v5 workflows.",
      "default": "300000",
      "examples": [
        "300000"
      ]
    },
    "github_script_version": {
      "type": "string",
      "description": "The version of the GitHub Script action to use in workflows.",
      "default": "v9",
      "examples": [
        "v9"
      ]
    },
    "setup_helmfile_version": {
      "type": "string",
      "description": "The version of the Setup Helmfile action to use in workflows.",
      "default": "v2.2.0",
      "examples": [
        "v2.2.0"
      ]
    }
  },
  "fileManifest": [
